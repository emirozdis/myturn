# Web Push (generate your own with: npx web-push generate-vapid-keys)
# Use https://localhost:3000 or http://localhost:3000 — not a LAN IP (192.168.x.x).
NEXT_PUBLIC_VAPID_KEY=**
VAPID_SUBJECT=mailto:info@domain.com

DATABASE_URL=**
DIRECT_URL=**

# Cloudflare R2 Credentials (for Server-Side upload/download/transcoding)
CLOUDFLARE_R2_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_s3_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_s3_secret_access_key"

# OPTIONAL: Define this if you want to use the Cloudflare Free Tier single bucket limit.
# If configured, R2 partitions logical buckets (vlogs, avatars) as folder prefixes inside this single bucket.
# If left empty, the code expects separate R2 buckets named "vlogs" and "avatars".
CLOUDFLARE_R2_BUCKET_NAME="myturn-dev"
NEXT_PUBLIC_MEDIA_URL="https://myturn-media-dev.yoursubdomain.workers.dev"

B2_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
B2_REGION="us-east-005"
B2_BUCKET_NAME="myturn-cold-archive"
B2_ACCESS_KEY_ID="005xxxxxxxxxxxxxxx"
B2_SECRET_ACCESS_KEY="K005xxxxxxxxxxxxxxxxxxxxxxx"

# Cryptographic Shared Secret for Token & Cookie Signatures
# (Must match the MEDIA_SECRET_KEY env variable in your Cloudflare Worker!)
MEDIA_SECRET_KEY="your_secure_random_signing_key_or_reuse_nextauth_secret"


NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=**
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=***

GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***

NEXT_PUBLIC_ALLOW_REGISTRATION="true"
NEXT_PUBLIC_ALLOW_SOCIAL_LOGIN="true"

# Individual social provider toggles ("true" or "false")
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN="true"
NEXT_PUBLIC_ENABLE_APPLE_LOGIN="false"
NEXT_PUBLIC_ENABLE_FACEBOOK_LOGIN="false"

NEXT_PUBLIC_ALLOW_WEB_BYPASS="true"

