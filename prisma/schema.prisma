generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// --- NextAuth Models ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Credentials provider
  
  // Custom Profile Attributes
  bio           String?   @default("Vlogging our days, making our memories ✨")
  handle        String?   @unique
  location      String?   @default("Phuket, Thailand")

  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  
  // App Relations
  groupMembers         GroupMember[]
  dailyAssignments     DailyAssignment[]
  clips                Clip[]
  reactions            Reaction[]
  pushSubscriptions    PushSubscription[]
  comments             Comment[]
  views                View[]
  unlockedAchievements UnlockedAchievement[]
  pokes                Poke[]
  
  friendRequestsSent     Friendship[] @relation("FriendRequestsSent")
  friendRequestsReceived Friendship[] @relation("FriendRequestsReceived")

  @@map("users")
}

model VerificationToken {
  id         String   @id @default(cuid()) 
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- App Models ---

model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())

  xp          Int      @default(0)      
  level       Int      @default(1)      

  members          GroupMember[]
  dailyAssignments DailyAssignment[]
  clips            Clip[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") 
  streak    Int      @default(0)
  joinedAt  DateTime @default(now())

  xp             Int      @default(0)      
  lastActiveAt   DateTime @default(now())  

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model DailyAssignment {
  id            String   @id @default(cuid())
  groupId       String
  userId        String
  date          DateTime @db.Date
  status        String   @default("active") 
  recapNotified Boolean  @default(false)
  createdAt     DateTime @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips Clip[]
  pokes Poke[]

  @@unique([groupId, date]) 
  @@index([groupId])
  @@index([userId])
  @@index([date])
  @@map("daily_assignments")
}

model Poke {
  id           String   @id @default(cuid())
  assignmentId String
  pokerId      String
  createdAt    DateTime @default(now())

  assignment DailyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  poker      User            @relation(fields: [pokerId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([pokerId])
  @@map("pokes")
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // "pending" | "accepted"
  createdAt   DateTime @default(now())

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@map("friendships")
}

model Clip {
  id            String   @id @default(cuid())
  assignmentId  String
  userId        String
  groupId       String
  videoUrl      String
  thumbnailUrl  String
  location      String?
  recordedAt    DateTime @default(now())

  assignment DailyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reactions  Reaction[]
  comments   Comment[]
  views      View[]

  @@index([assignmentId])
  @@index([userId])
  @@index([groupId])
  @@map("clips")
}

model Reaction {
  id        String   @id @default(cuid())
  clipId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([userId])
  @@map("reactions")
}

model Comment {
  id        String   @id @default(cuid())
  clipId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([userId])
  @@map("comments")
}

model View {
  id        String   @id @default(cuid())
  clipId    String
  userId    String
  createdAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clipId, userId])
  @@index([clipId])
  @@index([userId])
  @@map("views")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model UnlockedAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  groupId       String   @default("global")
  unlockedAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId, groupId])
  @@index([userId])
  @@map("unlocked_achievements")
}